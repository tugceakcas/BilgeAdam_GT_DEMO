{
  "name": "GT Demo Training",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "vscode",
  "forwardPorts": [
    6080
  ],
  "portsAttributes": {
    "6080": {
      "label": "noVNC browser demo",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-maven",
        "vscjava.vscode-java-test",
        "CucumberOpen.cucumber-official",
        "karatelabs.karate"
      ],
      "settings": {
        "java.configuration.updateBuildConfiguration": "automatic"
      }
    }
  },
  "postCreateCommand": "bash scripts/codespaces-doctor.sh --quick"
}
