{
  "java.configuration.updateBuildConfiguration": "automatic",
  "files.associations": {
    "**/features/api/**/*.feature": "karate",
    "**/features/web/**/*.feature": "cucumber",
    "**/features/mobile/**/*.feature": "cucumber",
    "**/features/training/**/*.feature": "cucumber"
  },
  "cucumber.features": [
    "**/features/web/**/*.feature",
    "**/features/mobile/**/*.feature",
    "**/features/training/**/*.feature"
  ],
  "cucumber.glue": [
    "**/src/test/java/com/gt/demo/web/**/*.java",
    "**/src/test/java/com/gt/demo/mobile/**/*.java"
  ],
  "java.test.config": [
    {
      "name": "web-headless",
      "testKind": "testng",
      "vmArgs": [
        "-Dwebdriver.headless=true"
      ]
    },
    {
      "name": "web-novnc",
      "testKind": "testng",
      "env": {
        "DISPLAY": ":99"
      },
      "vmArgs": [
        "-Dwebdriver.headless=false"
      ]
    }
  ],
  "java.test.defaultConfig": "web-headless"
}
